# ===================
# APP CONFIG
# ===================
NODE_ENV=development
PORT=3000

# ===================
# DATABASE CONFIG
# ===================
# PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Ejemplo local: postgresql://postgres:postgres@localhost:5432/todo_db?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/todo_db?schema=public"

# ===================
# AUTH CONFIG
# ===================
# JWT Secret - cambia esto en producción (usa una cadena larga y aleatoria, mínimo 32 caracteres)
JWT_SECRET="tu-jwt-secret-aqui-cambiar-en-produccion-minimo-32-caracteres"

# JWT Expiration time (ej: 24h, 7d, 1h)
JWT_EXPIRATION="24h"
# Refresh Token Expiration (en días)
REFRESH_TOKEN_EXPIRATION_DAYS=7

# Bcrypt Salt Rounds (10-12 es recomendado para producción)
# 10 = 2^10 iteraciones (aprox 100ms)
# 12 = 2^12 iteraciones (aprox 400ms) - más seguro pero más lento
BCRYPT_SALT_ROUNDS=10
