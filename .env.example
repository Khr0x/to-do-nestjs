# ===================
# APP CONFIG
# ===================
NODE_ENV=development
PORT=3000

# ===================
# DATABASE CONFIG
# ===================
# IMPORTANTE: 
# - Para desarrollo LOCAL (sin Docker): DB_HOST=localhost
# - Para desarrollo CON Docker: DB_HOST=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres123
DB_NAME=todo_db

# ===================
# AUTH CONFIG
# ===================
# JWT Secret - cambia esto en producción (usa una cadena larga y aleatoria, mínimo 32 caracteres)
JWT_SECRET="mi-super-secreto-jwt-para-desarrollo-cambiar-en-produccion-12345"

# JWT Expiration time (en segundos, ej: 86400 = 24h, 3600 = 1h)
JWT_EXPIRATION=86400

# Refresh Token Expiration (en días, ej: 7d)
REFRESH_TOKEN_EXPIRES_IN=7d

# Cookie Domain (opcional, ej: localhost para desarrollo)
COOKIE_DOMAIN=localhost

# Bcrypt Salt Rounds (10-12 es recomendado para producción)
BCRYPT_SALT_ROUNDS=10

# Frontend URL (para CORS y redirecciones)
FRONTEND_URL=http://localhost:4200